# Copy this file to ".env" and fill in your values. ".env" is git-ignored.
#   Windows:  copy env.example .env
#   macOS/Linux:  cp env.example .env

# --- Stage 2 (Ollama) ---
# Set to 0 to actually call Ollama; 1 (default) uses mock scores, no Ollama needed.
OLLAMA_MOCK=1
# Any model you have pulled locally. Check with: ollama list
OLLAMA_MODEL=qwen2.5-coder:7b

# --- Stage 3 (Claude, optional / paid) ---
# Set to 1 to enable the Claude adjudicator stage.
STAGE3_ENABLED=0
# Your Anthropic API key (only needed if STAGE3_ENABLED=1).
ANTHROPIC_API_KEY=
